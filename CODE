    def create_stat_box(self, parent, title, color):
        box = ctk.CTkFrame(parent, border_width=2, border_color=color, corner_radius=20)
        box.pack(side="left", expand=True, fill="both", padx=15)
        lbl = ctk.CTkLabel(box, text="0.0h", font=("Roboto", 65, "bold"), text_color=color)
        lbl.pack(pady=(30, 0))
        ctk.CTkLabel(box, text=title, font=("Roboto", 13, "bold"), text_color="gray").pack(pady=(0, 30))
        return lbl

    def load_images(self):
        self.star_faces = {}
        for star in ["Rajini", "Vijay", "Kamal", "Ajith"]:
            path = os.path.join(self.script_dir, f"{star.lower()}_face.png")
            self.star_faces[star] = ctk.CTkImage(Image.open(path), size=(120, 120)) if os.path.exists(path) else None
        
        hero_path = os.path.join(self.script_dir, "login_hero.png")
        self.login_hero_img = ctk.CTkImage(Image.open(hero_path), size=(350, 450)) if os.path.exists(hero_path) else None
        
        bed_path = os.path.join(self.script_dir, "bed_background.png")
        self.bed_img = ctk.CTkImage(Image.open(bed_path), size=(350, 220)) if os.path.exists(bed_path) else None

    # --- USER LOGIC ---
    def login(self):
        name = self.username_entry.get().strip()
        if not name: return
        self.current_user = name
        self.load_user_data()
        self.login_frame.place_forget()
        self.change_star(self.current_star)
        # Iconic Dialogue integrated at Login
        self.add_chat(f"RAJINI: Kanna {name}! Inga santhosam na enga ponalum santhosam tha... Inga santhosam illa na engayum illa. Start your recovery!")

    def load_user_data(self):
        if os.path.exists(self.db_file):
            with open(self.db_file, "r") as f:
                data = json.load(f)
                info = data.get(self.current_user, {"debt": 0.0})
                self.total_debt = info["debt"]
                self.update_ui_labels()

    def save_user_data(self):
        data = {}
        if os.path.exists(self.db_file):
            with open(self.db_file, "r") as f: data = json.load(f)
        data[self.current_user] = {"debt": self.total_debt}
        with open(self.db_file, "w") as f: json.dump(data, f)

    # --- STAR ACTIONS ---
    def quick_action(self, choice):
        if choice == 1: # DEBT CHECK
            lines = {
                "Rajini": f"Kanna! Debt {self.total_debt:.1f}h. Naan oru thadava sonna nooru thadava sonna madhiri... go to sleep!",
                "Vijay": f"Nanba! Debt {self.total_debt:.1f}h. Life is short, stay happy and rest well.",
                "Kamal": f"Physiological deficit is {self.total_debt:.1f}h. Circadian synchronization required.",
                "Ajith": f"Debt: {self.total_debt:.1f}h. Discipline is the only way. Stay focused."
            }
            self.add_chat(lines[self.current_star])
        elif choice == 2: # RANDOM QUOTE / HEALTH SECRET
            self.add_chat(f"{self.current_star}: {random.choice(self.sleep_quotes)}")
        elif choice == 3: # MUSIC
            d = random.choice(list(self.song_db.keys()))
            songs = random.sample(self.song_db[d], 3)
            self.add_chat(f"{self.current_star}: Relax with {d} hits:\n\n✨ {songs[0]}\n✨ {songs[1]}\n✨ {songs[2]}")

    def change_star(self, name):
        self.current_star = name
        self.face_label.configure(image=self.star_faces.get(name))
        quotes = {
            "Rajini": f"Kanna {self.current_user}! Magizhchi! Let's clear that debt.",
            "Vijay": f"Nanba! I'm waiting for your recovery streak!",
            "Kamal": f"Greetings {self.current_user}. Analyzing biological data...",
            "Ajith": f"Hello {self.current_user}. Guts and Great Sleep. No shortcuts."
        }
        self.greet_label.configure(text=quotes.get(name))
        self.add_chat(f"MODE: {name} personality activated.")

    def update_sleep_stats(self):
        try:
            val = float(self.sleep_input.get())
            self.total_debt += (8.0 - val)
            if self.total_debt < 0: self.total_debt = 0
            self.update_ui_labels()
            self.save_user_data()
            self.sleep_input.delete(0, 'end')
            self.add_chat(f"{self.current_star}: Logged {val}h. Debt recalculated.")
        except: pass

    def update_ui_labels(self):
        target = 8.0 + (self.total_debt * 0.2)
        self.debt_display.configure(text=f"{self.total_debt:.1f}h")
        self.goal_display.configure(text=f"{target:.1f}h")

    def add_chat(self, text):
        self.chat_display.configure(state="normal")
        self.chat_display.insert("end", text + "\n\n")
        self.chat_display.configure(state="disabled")
        self.chat_display.see("end")

